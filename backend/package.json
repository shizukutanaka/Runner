{
  "name": "youtube-twitch-comment-manager-backend",
  "version": "2.1.0",
  "description": "Enterprise-grade live streaming comment management platform with advanced AI moderation, real-time processing, and comprehensive security features.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js --watch src --ext js,json",
    "predev": "node src/scripts/checkEnv.js",
    "dev:secure": "npm run security:check && npm run dev",
    "start": "pm2 start ecosystem.config.js --env production",
    "start:dev": "pm2 start ecosystem.config.js --env development",
    "start:staging": "pm2 start ecosystem.config.js --env staging",
    "start:node": "node src/server.js",
    "prestart": "node src/scripts/checkEnv.js",
    "start:cluster": "node src/cluster.js",
    "stop": "pm2 stop ecosystem.config.js",
    "restart": "pm2 restart ecosystem.config.js",
    "reload": "pm2 reload ecosystem.config.js",
    "status": "pm2 status",
    "monit": "pm2 monit",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch --detectOpenHandles",
    "test:coverage": "jest --coverage --coverageReporters=html --detectOpenHandles",
    "test:e2e": "jest --testPathPattern=e2e --detectOpenHandles",
    "test:integration": "jest --testPathPattern=integration --detectOpenHandles",
    "test:unit": "jest --testPathPattern=unit --detectOpenHandles",
    "test:security": "npm audit --audit-level moderate && npm run test:unit",
    "lint": "eslint src/ --ext .js,.json",
    "lint:fix": "eslint src/ --ext .js,.json --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "security:check": "npm audit --audit-level high && snyk test",
    "security:fix": "npm audit fix && snyk wizard",
    "db:init": "node src/scripts/initDatabase.js",
    "db:migrate": "node src/scripts/migrate.js",
    "db:seed": "node src/scripts/seed.js",
    "db:backup": "node src/scripts/backup.js",
    "db:restore": "node src/scripts/restore.js",
    "build": "npm run lint && npm run test && npm run security:check",
    "build:production": "NODE_ENV=production npm run build",
    "deploy": "npm run build:production && pm2 start ecosystem.config.js",
    "deploy:production": "npm run build:production && pm2 start ecosystem.config.js --env production",
    "deploy:staging": "npm run build && pm2 start ecosystem.config.js --env staging",
    "install:secure": "npm ci --only=production && npm audit fix",
    "precommit": "npm run lint && npm run test:unit",
    "prepare": "husky install",
    "docker:build": "docker build -t comment-manager:latest .",
    "docker:run": "docker run -p 3000:3000 comment-manager:latest",
    "docker:compose": "docker-compose up -d",
    "k8s:deploy": "kubectl apply -f k8s/",
    "monitoring:start": "node src/scripts/monitoring.js",
    "backup:create": "node src/scripts/createBackup.js",
    "backup:restore": "node src/scripts/restoreBackup.js",
    "health:check": "node src/scripts/healthCheck.js",
    "env:check": "node src/scripts/checkEnv.js",
    "logs:tail": "pm2 logs --lines 100",
    "logs:clear": "pm2 flush",
    "performance:test": "artillery run performance/load-test.yml",
    "performance:benchmark": "node src/scripts/benchmark.js"
  },
  "keywords": [
    "youtube",
    "twitch",
    "comments",
    "moderation",
    "ai",
    "real-time",
    "streaming",
    "enterprise",
    "security",
    "scalability",
    "websocket",
    "api",
    "nodejs",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "aframe": "^1.4.2",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "compromise": "^14.8.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "franc": "^6.0.0",
    "googleapis": "^118.0.0",
    "helmet": "^8.2.0",
    "i18next": "^23.7.0",
    "i18next-fs-backend": "^2.3.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^9.0.3",
    "openai": "^5.0.1",
    "pm2": "^5.3.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.6.12",
    "socket.io": "^4.7.5",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.6",
    "stripe": "^14.24.0",
    "systeminformation": "^5.23.7",
    "three": "^0.158.0",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^4.7.1",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "artillery": "^2.0.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.6.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^1.7.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.1.0",
    "snyk": "^1.1267.0",
    "supertest": "^6.3.3"
  },
  "repository": {
    "type": "git"
  },
  "bugs": {},
  "homepage": "",
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ],
    "*.json": [
      "prettier --write",
      "git add"
    ]
  },
  "eslintConfig": {
    "extends": [
      "airbnb-base",
      "prettier",
      "plugin:security/recommended",
      "plugin:jest/recommended"
    ],
    "plugins": [
      "security",
      "jest"
    ],
    "env": {
      "node": true,
      "jest": true,
      "es6": true
    },
    "rules": {
      "no-console": "warn",
      "security/detect-object-injection": "off",
      "import/no-dynamic-require": "off",
      "global-require": "off",
      "no-param-reassign": "off",
      "consistent-return": "off",
      "no-unused-vars": "error",
      "no-process-exit": "off"
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 100,
    "endOfLine": "lf"
  },
  "nodemonConfig": {
    "ignore": [
      "tests/",
      "data/",
      "logs/",
      "node_modules/"
    ],
    "env": {
      "NODE_ENV": "development"
    }
  },
  "directories": {
    "test": "tests",
    "lib": "src"
  },
  "files": [
    "src/",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ]
}
