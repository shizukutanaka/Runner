# YouTube & Twitch Comment Manager - Environment Configuration
# ===================================================================
# SECURITY WARNING: Never commit actual API keys or secrets to version control
# Copy this file to .env and update with your actual values

# ===================================================================
# APPLICATION CONFIGURATION
# ===================================================================
NODE_ENV=development
PORT=3000
APP_NAME="YouTube & Twitch Comment Manager"
APP_VERSION=2.1.0

# ===================================================================
# SECURITY CONFIGURATION
# ===================================================================
# JWT Secret - MUST be 32+ characters for production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Session Secret - MUST be 32+ characters for production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Session store configuration
SESSION_STORE=memory
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=strict
SESSION_MAX_AGE=86400000
# SESSION_REDIS_URL=redis://localhost:6379
# SESSION_REDIS_PREFIX=runner:sess:
# SESSION_COOKIE_DOMAIN=example.com
# SESSION_ROLLING=true

# Encryption Key for sensitive data - MUST be 32+ characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ===================================================================
# ADVANCED SECURITY FEATURES
# ===================================================================
# Two-Factor Authentication (2FA)
ENABLE_2FA=true
TOTP_WINDOW=2
BACKUP_CODES_COUNT=10

# IP Whitelisting
ENABLE_IP_WHITELIST=false
# GLOBAL_WHITELIST_IPS=127.0.0.1,::1

# Session Security
MAX_SESSIONS_PER_USER=5
SESSION_HIJACK_DETECTION=true
SESSION_CLEANUP_INTERVAL=3600000

# CSRF Protection
CSRF_ENABLED=true
CSRF_TOKEN_EXPIRY=3600000

# Token Rotation
TOKEN_ROTATION_ENABLED=true
TOKEN_FAMILY_SIZE=10
DETECT_TOKEN_REUSE=true

# Webhook Security
WEBHOOK_SIGNATURE_ALGORITHM=sha256
WEBHOOK_EVENT_EXPIRY=300000
WEBHOOK_MAX_PROCESSED_EVENTS=10000
WEBHOOK_RATE_LIMIT=60

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================
# SQLite (Development)
DATABASE_URL=sqlite:./data/database.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://username:password@localhost:5432/commentmanager

# ===================================================================
# CACHE CONFIGURATION (Redis)
# ===================================================================
# Redis URL (Optional - falls back to memory cache)
REDIS_URL=redis://localhost:6379

# Cache settings
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Query optimization
QUERY_CACHE_ENABLED=true
QUERY_CACHE_TTL=300000
QUERY_CACHE_MAX_SIZE=1000
SLOW_QUERY_THRESHOLD=1000

# Response caching
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_TTL=300000
RESPONSE_CACHE_MAX_SIZE=500

# Connection pooling
DB_POOL_SIZE=5
DB_BUSY_TIMEOUT=5000

# ===================================================================
# API KEYS - REQUIRED FOR FUNCTIONALITY
# ===================================================================
# OpenAI API Key for AI moderation and content analysis (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# YouTube Data API v3 Key
YOUTUBE_API_KEY=

# Twitch API Credentials
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ===================================================================
# STRIPE BILLING INTEGRATION
# ===================================================================
# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe redirect URLs
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/settings/billing

# Stripe plan pricing (in smallest currency unit, e.g., cents for USD, yen for JPY)
STRIPE_PLAN_MIN_MONTHLY_AMOUNT=12000
STRIPE_PLAN_PROFESSIONAL_MONTHLY_AMOUNT=12000
STRIPE_PLAN_ENTERPRISE_MONTHLY_AMOUNT=24000
STRIPE_PLAN_CURRENCY=jpy
STRIPE_PLAN_INTERVAL=month

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRICE_ID_PROFESSIONAL=
STRIPE_PRICE_ID_PROFESSIONAL_ONETIME=
STRIPE_PRICE_ID_ENTERPRISE=
STRIPE_PRICE_ID_ENTERPRISE_ONETIME=

# Professional Plan Configuration
STRIPE_PLAN_PROFESSIONAL_CURRENCY=jpy
STRIPE_PLAN_PROFESSIONAL_INTERVAL=month
STRIPE_PLAN_PROFESSIONAL_SEATS=10

# Enterprise Plan Configuration
STRIPE_PLAN_ENTERPRISE_CURRENCY=jpy
STRIPE_PLAN_ENTERPRISE_INTERVAL=month
STRIPE_PLAN_ENTERPRISE_SEATS=50

# ===================================================================
# RATE LIMITING CONFIGURATION
# ===================================================================
# Rate limiting windows (in milliseconds)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# DDoS protection threshold
DDOS_RATE_LIMIT=50

# ===================================================================
# BACKUP & STORAGE CONFIGURATION
# ===================================================================
# Enable automatic backups
AUTO_BACKUP=true
BACKUP_SCHEDULE=0 2 * * *
MAX_BACKUPS=30
ENCRYPT_BACKUPS=true

# Remote backup storage (optional)
# REMOTE_BACKUP_URL=s3://your-backup-bucket

# ===================================================================
# MONITORING & LOGGING
# ===================================================================
# Log level (error, warn, info, debug)
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Monitoring endpoints
# MONITORING_ENDPOINT=https://your-monitoring-service.com
# ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ===================================================================
# SECURITY HEADERS & CORS
# ===================================================================
# CORS origin (production should be specific domain)
CORS_ORIGIN=http://localhost:5173

# Security headers
HELMET_ENABLED=true

# ===================================================================
# MODERATION SETTINGS
# ===================================================================
# AI moderation rejection score threshold (0-100)
MODERATION_REJECTION_SCORE=60

# Comment length limits
MAX_COMMENT_LENGTH=2000

# ===================================================================
# EXTERNAL INTEGRATIONS (Optional)
# ===================================================================
# Email service configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Webhook notifications
# SLACK_WEBHOOK_URL=
# DISCORD_WEBHOOK_URL=

# ===================================================================
# PERFORMANCE & SCALING
# ===================================================================
# Cluster mode (set to true for production)
CLUSTER_MODE=false

# Database connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Request timeout (milliseconds)
REQUEST_TIMEOUT=30000

# ===================================================================
# DEVELOPMENT SETTINGS
# ===================================================================
# Enable detailed error messages in development
DEBUG_MODE=true

# Skip authentication for development (NEVER use in production)
SKIP_AUTH=false

# Enable API documentation
ENABLE_SWAGGER=true

# ===================================================================
# FEATURE FLAGS
# ===================================================================
# Enable/disable specific features
ENABLE_AI_MODERATION=true
ENABLE_REAL_TIME_SYNC=true
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_BACKUP=true

# ===================================================================
# COMPLIANCE & GOVERNANCE
# ===================================================================
# Data retention period (in days)
DATA_RETENTION_DAYS=365

# Enable audit logging
AUDIT_LOGGING=true
AUDIT_LOG_RETENTION_DAYS=730

# GDPR compliance features
GDPR_ENABLED=true
GDPR_DATA_RETENTION_COMMENTS=90
GDPR_DATA_RETENTION_USERS=365
GDPR_DATA_RETENTION_SESSIONS=30
GDPR_DATA_RETENTION_LOGS=180
GDPR_DATA_RETENTION_ANALYTICS=730
GDPR_EXPORT_EXPIRY_DAYS=7

# Consent management
CONSENT_REQUIRED=true
DEFAULT_CONSENT_TYPES=essential,functional,analytics

# ===================================================================
# PLATFORM-SPECIFIC SETTINGS
# ===================================================================
# YouTube specific settings
YOUTUBE_POLLING_INTERVAL=5000
YOUTUBE_MAX_RESULTS=100

# Twitch specific settings
TWITCH_POLLING_INTERVAL=3000
TWITCH_MAX_RESULTS=50

# ===================================================================
# HEALTH CHECK & MONITORING
# ===================================================================
# Health check intervals (milliseconds)
HEALTH_CHECK_INTERVAL=60000

# Memory usage threshold (MB)
MEMORY_THRESHOLD=512

# CPU usage threshold (percentage)
CPU_THRESHOLD=80

# ===================================================================
# ALERTING CONFIGURATION
# ===================================================================
# Alert thresholds
ALERT_ERROR_RATE=0.05
ALERT_RESPONSE_TIME=1000
ALERT_MEMORY_USAGE=0.9
ALERT_CPU_USAGE=0.8
ALERT_DISK_USAGE=0.85
ALERT_FAILED_LOGINS=5
ALERT_RATE_LIMIT_VIOLATIONS=10

# Alert history
ALERT_HISTORY_MAX_SIZE=1000

# System metrics check interval (milliseconds)
METRICS_CHECK_INTERVAL=30000

# Security metrics check interval (milliseconds)
SECURITY_METRICS_INTERVAL=60000

# Cleanup old metrics interval (milliseconds)
METRICS_CLEANUP_INTERVAL=3600000

# ===================================================================
# CIRCUIT BREAKER CONFIGURATION
# ===================================================================
# Circuit breaker settings for external APIs
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2
CIRCUIT_BREAKER_TIMEOUT=30000
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# ===================================================================
# ADDITIONAL NOTES
# ===================================================================
# 1. For production deployment, set NODE_ENV=production
# 2. Use strong, randomly generated secrets for all _SECRET and _KEY variables
#    Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Configure Redis for distributed caching in production
# 4. Set up proper monitoring and alerting endpoints
# 5. Enable automatic backups for data protection
# 6. Configure CORS_ORIGIN to your actual domain
# 7. Review and adjust rate limiting based on your usage patterns
# 8. Enable 2FA for enhanced security (ENABLE_2FA=true)
# 9. Configure IP whitelisting for sensitive operations (ENABLE_IP_WHITELIST=true)
# 10. Set SESSION_COOKIE_SECURE=true when using HTTPS
# 11. Enable GDPR compliance features for EU users (GDPR_ENABLED=true)
# 12. Configure circuit breaker for external API resilience
# 13. Set appropriate alert thresholds for your infrastructure
# 14. Review data retention policies for compliance requirements
# 15. Enable audit logging for security compliance (AUDIT_LOGGING=true)
