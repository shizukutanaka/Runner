# YouTube & Twitch Comment Manager - Frontend Configuration
# ===================================================================
# Copy this file to .env and update with your actual values

# ===================================================================
# APPLICATION CONFIGURATION
# ===================================================================
VITE_APP_NAME="YouTube & Twitch Comment Manager"
VITE_APP_VERSION=2.1.0

# ===================================================================
# API CONFIGURATION
# ===================================================================
# Backend API base URL
VITE_API_BASE_URL=http://localhost:3000/api

# WebSocket connection URL
VITE_WS_URL=ws://localhost:3000

# ===================================================================
# DEVELOPMENT SETTINGS
# ===================================================================
# Enable development tools
VITE_DEV_TOOLS=true

# Enable debug mode
VITE_DEBUG=true

# Show detailed error messages
VITE_SHOW_ERRORS=true

# Enable MSW for API mocking in development (set to 'true' to enable)
VITE_ENABLE_MSW=false

# ===================================================================
# FEATURE FLAGS
# ===================================================================
# Enable/disable specific features
VITE_ENABLE_AI_MODERATION=true
VITE_ENABLE_REAL_TIME=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_THEMES=true
VITE_ENABLE_I18N=true

# ===================================================================
# UI CONFIGURATION
# ===================================================================
# Default theme (light, dark, system)
VITE_DEFAULT_THEME=system

# Default language (en, ja, zh, ko, es, fr, de, pt, ru, ar)
VITE_DEFAULT_LANGUAGE=en

# Default timezone
VITE_DEFAULT_TIMEZONE=UTC

# ===================================================================
# PERFORMANCE SETTINGS
# ===================================================================
# WebSocket reconnection attempts
VITE_WS_RECONNECT_ATTEMPTS=5

# WebSocket reconnection delay (ms)
VITE_WS_RECONNECT_DELAY=1000

# API request timeout (ms)
VITE_API_TIMEOUT=30000

# Cache TTL for static data (ms)
VITE_CACHE_TTL=300000

# ===================================================================
# MONITORING & ANALYTICS
# ===================================================================
# Enable performance monitoring
VITE_ENABLE_MONITORING=false

# Analytics tracking ID (optional)
# VITE_ANALYTICS_ID=your-analytics-id

# Error reporting service (optional)
# VITE_ERROR_REPORTING_URL=

# ===================================================================
# EXTERNAL INTEGRATIONS
# ===================================================================
# Enable external integrations
VITE_ENABLE_WEBHOOKS=true

# Support links (remove non-existent URLs)
VITE_SUPPORT_EMAIL=contact@example.com

# ===================================================================
# SECURITY SETTINGS
# ===================================================================
# Content Security Policy
VITE_CSP_ENABLED=true

# Enable HTTPS only in production
VITE_HTTPS_ONLY=false

# Two-Factor Authentication UI
VITE_ENABLE_2FA_UI=true

# Session security
VITE_SESSION_TIMEOUT_WARNING=300000
VITE_AUTO_LOGOUT_INACTIVE=1800000

# ===================================================================
# BUILD CONFIGURATION
# ===================================================================
# Build optimization level
VITE_BUILD_OPTIMIZATION=true

# Enable source maps in production
VITE_BUILD_SOURCEMAPS=false

# Enable bundle analysis
VITE_ANALYZE_BUNDLE=false

# ===================================================================
# PRODUCTION OVERRIDES
# ===================================================================
# Production API URL (uncomment for production)
# VITE_API_BASE_URL=https://your-domain.com/api
# VITE_WS_URL=wss://your-domain.com

# Production settings
# VITE_DEBUG=false
# VITE_SHOW_ERRORS=false
# VITE_DEV_TOOLS=false
# VITE_HTTPS_ONLY=true
# VITE_SESSION_COOKIE_SECURE=true

# ===================================================================
# PERSONAL USE OPTIMIZATION
# ===================================================================
# For single-user or small team deployments

# Simplified authentication (for personal use)
# VITE_SKIP_REGISTRATION=true
# VITE_AUTO_LOGIN_DEV=true

# Enhanced privacy
# VITE_DISABLE_ANALYTICS=true
# VITE_DISABLE_EXTERNAL_TRACKING=true

# Local-first mode (minimal external dependencies)
# VITE_LOCAL_MODE=true
# VITE_OFFLINE_SUPPORT=true