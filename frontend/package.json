{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "YouTube & Twitch Comment Manager Frontend - React.js application with Material-UI",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint src/ --ext js,jsx",
    "lint:fix": "eslint src/ --ext js,jsx --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "generate-translations": "node generate-translations.js",
    "translation-manager": "node translation-manager.js",
    "translation-stats": "node translation-manager.js stats",
    "translation-missing": "node translation-manager.js missing",
    "translation-quality": "node translation-manager.js quality",
    "translation-sync": "node translation-manager.js sync",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "audit:production": "npm audit --audit-level=high --production"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@mui/x-charts": "^6.18.1",
    "axios": "^1.18.1",
    "i18next": "^23.7.6",
    "i18next-browser-languagedetector": "^8.2.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "react-virtuoso": "^4.7.10",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@storybook/addon-essentials": "^7.6.3",
    "@storybook/addon-interactions": "^7.6.3",
    "@storybook/addon-links": "^7.6.3",
    "@storybook/blocks": "^7.6.3",
    "@storybook/react": "^7.6.3",
    "@storybook/react-vite": "^7.6.3",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitalets/google-translate-api": "^9.2.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "msw": "^2.0.11",
    "prettier": "^3.1.0",
    "storybook": "^7.6.3",
    "terser": "^5.48.0",
    "vite": "^5.0.8",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^1.1.0"
  },
  "keywords": [
    "youtube",
    "twitch",
    "comment",
    "management",
    "react",
    "material-ui"
  ],
  "author": "",
  "license": "ISC"
}
